     ]
    }
   ],
   "source": [
    "# ============================================================\n",
    "#  STEP 2 — COMBINE TRAIN + TEST FOR PREPROCESSING\n"
    "# ============================================================\n",
    "train_data = train.drop(columns=['SalePrice', 'Id'])\n",
    "test_data  = test.drop(columns=['Id'])\n",
    "n_train    = len(train_data)\n",
    "\n",
    "all_data = pd.concat([train_data, test_data], axis=0).reset_index(drop=True)\n",
    "print(f\"\\nCombined shape (train+test): {all_data.shape}\")\n"
   ]
  },
