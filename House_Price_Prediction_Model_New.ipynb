   "source": [
    "# ============================================================\n",
    "#  STEP 12 — WEIGHTED ENSEMBLE PREDICTION\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"STEP 12 — ENSEMBLE PREDICTION\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "ridge_preds = np.expm1(ridge.predict(X_sub_sc))\n",
    "lasso_preds = np.expm1(lasso.predict(X_sub_sc))\n",
    "xgb_preds   = np.expm1(xgb.predict(X_submit))\n",
    "\n",
    "# Weight by inverse RMSE — better model gets more say\n",
    "w_r = 1 / r_rmse\n",
    "w_l = 1 / l_rmse\n",
    "w_x = 1 / x_rmse\n",
    "w_t = w_r + w_l + w_x\n",
    "\n",
    "ensemble_preds = (w_r * ridge_preds +\n",
    "                  w_l * lasso_preds +\n",
    "                  w_x * xgb_preds) / w_t\n",
    "\n",
    "print(f\"Ridge   weight : {w_r/w_t:.3f}\")\n",
    "print(f\"Lasso   weight : {w_l/w_t:.3f}\")\n",
    "print(f\"XGBoost weight : {w_x/w_t:.3f}\")"
   ]
  },
