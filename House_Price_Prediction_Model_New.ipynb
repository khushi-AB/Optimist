   "source": [
    "# ============================================================\n",
    "#  STEP 9 — SPLIT BACK + TRAIN/VAL SPLIT + SCALE\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"STEP 9 — TRAIN/VAL SPLIT + SCALING\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "X_all    = all_data.iloc[:n_train].copy()\n",
    "X_submit = all_data.iloc[n_train:].copy()\n",
    "\n",
    "X_train, X_val, y_train, y_val = train_test_split(\n",
    "    X_all, y, test_size=0.2, random_state=42)\n",
    "\n",
    "scaler     = StandardScaler()\n",
    "X_train_sc = scaler.fit_transform(X_train)\n",
    "X_val_sc   = scaler.transform(X_val)\n",
    "X_sub_sc   = scaler.transform(X_submit)\n",
    "\n",
    "print(f\"X_train : {X_train.shape}\")\n",
    "print(f\"X_val   : {X_val.shape}\")\n",
    "print(f\"X_submit: {X_submit.shape}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "348dead3-0562-4e28-9359-bf72e781f17a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "=======================================================\n",
      "STEP 10 — MODEL TRAINING\n",
      "=======================================================\n",
      "Ridge      -> Val RMSE: 0.1354  |  CV RMSE: 0.1416\n",
      "Lasso      -> Val RMSE: 0.1367  |  CV RMSE: 0.1402  |  Features kept: 143\n",
      "XGBoost    -> Val RMSE: 0.1360  |  Best iter: 1077\n"
     ]
    }
   ],
   "source": [
    "\n",
    "# ============================================================\n",
    "#  STEP 10 — TRAIN MODELS\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"STEP 10 — MODEL TRAINING\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "results = {}\n",
    "\n",
    "# ── Ridge ──────────────────────────────────────────────────\n",
    "ridge = Ridge(alpha=10)\n",
    "ridge.fit(X_train_sc, y_train)\n",
    "r_pred = ridge.predict(X_val_sc)\n",
    "r_rmse = np.sqrt(mean_squared_error(y_val, r_pred))\n",
    "r_cv   = -cross_val_score(ridge, X_train_sc, y_train,\n",
    "                           cv=5, scoring='neg_root_mean_squared_error').mean()\n",
    "results['Ridge'] = {'val_rmse': r_rmse, 'cv_rmse': r_cv}\n",
    "print(f\"Ridge      -> Val RMSE: {r_rmse:.4f}  |  CV RMSE: {r_cv:.4f}\")\n",
    "\n",
    "# ── Lasso ──────────────────────────────────────────────────\n",
    "lasso = Lasso(alpha=0.0005, max_iter=10000)\n",
    "lasso.fit(X_train_sc, y_train)\n",
    "l_pred = lasso.predict(X_val_sc)\n",
    "l_rmse = np.sqrt(mean_squared_error(y_val, l_pred))\n",
    "l_cv   = -cross_val_score(lasso, X_train_sc, y_train,\n",
    "                           cv=5, scoring='neg_root_mean_squared_error').mean()\n",
    "results['Lasso'] = {'val_rmse': l_rmse, 'cv_rmse': l_cv}\n",
    "n_kept = (lasso.coef_ != 0).sum()\n",
    "print(f\"Lasso      -> Val RMSE: {l_rmse:.4f}  |  CV RMSE: {l_cv:.4f}  |  Features kept: {n_kept}\")\n",
    "\n",
    "# ── XGBoost ────────────────────────────────────────────────\n",
    "xgb = XGBRegressor(\n",
    "    n_estimators          = 2000,\n",
    "    learning_rate         = 0.01,\n",
    "    max_depth             = 4,\n",
    "    min_child_weight      = 2,\n",
    "    subsample             = 0.8,\n",
    "    colsample_bytree      = 0.7,\n",
    "    reg_alpha             = 0.01,\n",
    "    reg_lambda            = 1.5,\n",
    "    random_state          = 42,\n",
    "    verbosity             = 0,\n",
    "    early_stopping_rounds = 50,\n",
    ")\n",
    "xgb.fit(X_train, y_train,\n",
    "        eval_set=[(X_val, y_val)],\n",
    "        verbose=False)\n",
    "x_pred = xgb.predict(X_val)\n",
    "x_rmse = np.sqrt(mean_squared_error(y_val, x_pred))\n",
    "results['XGBoost'] = {'val_rmse': x_rmse, 'cv_rmse': x_rmse}\n",
    "print(f\"XGBoost    -> Val RMSE: {x_rmse:.4f}  |  Best iter: {xgb.best_iteration}\")\n"
   ]
  },
