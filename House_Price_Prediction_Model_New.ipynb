   "source": [
    "# ============================================================\n",
    "#  STEP 6 — VIF ON CONTINUOUS NUMERIC FEATURES ONLY\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"STEP 6 — VIF CHECK (continuous numeric only, pre-encoding)\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    
    "vif_candidates = all_data.select_dtypes(include=[np.number]).columns.tolist()\n",
    
    "binary_flags = ['WasRemodeled', 'HasFireplace']\n",
    "vif_cols     = [c for c in vif_candidates if c not in binary_flags]\n",
    "\n",
    
    "vif_data = all_data.iloc[:n_train][vif_cols].dropna()\n",
    "\n",
    
    "scaler_vif = StandardScaler()\n",
    "vif_scaled = pd.DataFrame(\n",
    "    scaler_vif.fit_transform(vif_data),\n",
    "    columns=vif_data.columns\n",
    ")\n",
    "\n",
    "vif_result = pd.DataFrame({\n",
    "    \"Feature\": vif_scaled.columns,\n",
    "    \"VIF\":     [variance_inflation_factor(vif_scaled.values, i)\n",
    "                for i in range(vif_scaled.shape[1])]\n",
    "}).sort_values(\"VIF\", ascending=False)\n",
    "\n",
    "print(\"\\nVIF Scores (scaled continuous features):\")\n",
    "print(vif_result.to_string(index=False))\n",
    "print(f\"\\nFeatures with VIF > 10 : {(vif_result['VIF'] > 10).sum()}\")\n",
    "print(f\"Features with VIF 5-10 : {((vif_result['VIF'] > 5) & (vif_result['VIF'] <= 10)).sum()}\")\n",
    "print(f\"Features with VIF < 5  : {(vif_result['VIF'] <= 5).sum()}\")\n",
    "\n",
    
    "high_vif = vif_result[vif_result['VIF'] > 10]['Feature'].tolist()\n",
    "if high_vif:\n",
    "    print(f\"\\nDropping collinear features: {high_vif}\")\n",
    "    all_data.drop(columns=high_vif, errors='ignore', inplace=True)\n",
    "else:\n",
    "    print(\"\\nAll continuous features have VIF < 10 — clean!\")\n"
   ]
