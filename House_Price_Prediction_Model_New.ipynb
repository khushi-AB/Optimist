   "source": [
    "# ============================================================\n",
    "#  STEP 5 — FEATURE ENGINEERING\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"STEP 5 — FEATURE ENGINEERING\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "# Age features\n",
    "all_data['HouseAge']     = all_data['YrSold'] - all_data['YearBuilt']\n",
    "all_data['RemodAge']     = all_data['YrSold'] - all_data['YearRemodAdd']\n",
    "all_data['WasRemodeled'] = (all_data['YearBuilt'] != all_data['YearRemodAdd']).astype(int)\n",
    "\n",
    "# Bath aggregate\n",
    "all_data['TotalBath'] = (all_data['FullBath']\n",
    "                       + all_data['BsmtFullBath']\n",
    "                       + 0.5 * all_data['HalfBath']\n",
    "                       + 0.5 * all_data['BsmtHalfBath'])\n",
    "\n",
    "# Porch aggregate\n",
    "all_data['TotalPorchSF'] = (all_data['OpenPorchSF'] + all_data['EnclosedPorch']\n",
    "                           + all_data['3SsnPorch']   + all_data['ScreenPorch'])\n",
    "\n",
    "# Area and ratio features\n",
    "all_data['TotalSF']      = all_data['TotalBsmtSF'] + all_data['GrLivArea']\n",
    "all_data['GarageRatio']  = all_data['GarageArea']  / (all_data['LotArea'] + 1)\n",
    "all_data['HasFireplace'] = (all_data['Fireplaces']  > 0).astype(int)\n",
    "\n",
    
    "drop_cols = [\n",
    "    'BsmtFinSF1', 'BsmtFinSF2', 'BsmtUnfSF',          # -> TotalBsmtSF kept in TotalSF\n",
    "    '1stFlrSF', '2ndFlrSF', 'LowQualFinSF',            # -> GrLivArea kept in TotalSF\n",
    "    'FullBath', 'BsmtFullBath', 'HalfBath', 'BsmtHalfBath',  # -> TotalBath\n",
    "    'OpenPorchSF', 'EnclosedPorch', '3SsnPorch', 'ScreenPorch', # -> TotalPorchSF\n",
    "    'YearBuilt', 'YearRemodAdd', 'YrSold', 'GarageYrBlt',       # -> age features\n",
    "    'GarageCars', 'TotRmsAbvGrd',                       # correlated with area\n",
    "    'GarageArea',                                        # -> GarageRatio\n",
    "    'TotalBsmtSF', 'GrLivArea',                         # -> TotalSF\n",
    "    'PoolArea', 'MiscVal',                               # near-zero variance\n",
    "    'Street', 'Utilities', 'Condition2', 'RoofMatl',    # near-constant\n",
    "]\n",
    "all_data.drop(columns=[c for c in drop_cols if c in all_data.columns],\n",
    "              inplace=True)\n",
    "\n",
    "print(f\"Shape after feature engineering: {all_data.shape}\")\n"
   ]
