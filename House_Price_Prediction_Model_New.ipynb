    "# ============================================================\n",
    "#  STEP 8 — FIX SKEWNESS\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"STEP 8 — FIX SKEWNESS\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "num_feats = all_data.select_dtypes(include=[np.number]).columns\n",
    "skewed    = all_data[num_feats].apply(skew).sort_values(ascending=False)\n",
    "skew_cols = skewed[abs(skewed) > 0.75].index.tolist()\n",
    "print(f\"Skewed features fixed: {len(skew_cols)}\")\n",
    "all_data[skew_cols] = np.log1p(all_data[skew_cols].clip(lower=0))\n"
   ]
